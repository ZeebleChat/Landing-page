{
	admin off
	auto_https off
}

# HTTP → HTTPS redirect
:{$HTTP_PORT:-8082} {
	redir https://{host}:{$HTTPS_PORT:-8445}{uri} permanent
}

zeeble.xyz:{$HTTPS_PORT:-8445} {
	tls {$TLS_CERT} {$TLS_KEY}
	reverse_proxy landing:80

	log {
		output stdout
	}
}

www.zeeble.xyz:{$HTTPS_PORT:-8445} {
	tls {$TLS_CERT} {$TLS_KEY}
	redir https://zeeble.xyz{uri} permanent
}
